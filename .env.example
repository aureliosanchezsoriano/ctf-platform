# Database
POSTGRES_USER=ctf
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ctfdb
DATABASE_URL=postgresql+asyncpg://ctf:changeme@db:5432/ctfdb

# Redis
REDIS_URL=redis://redis:6379/0

# Security
# SECRET_KEY -> JWT signature
SECRET_KEY=changeme-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Flag engine
# FLAT_HMAC_SECRET -> Flag integrity secret, HMAC
FLAG_HMAC_SECRET=changeme-different-from-secret-key
FLAG_PREFIX=CTF

# Docker
DOCKER_SOCKET=/var/run/docker.sock
CONTAINER_NETWORK_PREFIX=ctf_user

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173
